# SD_image_upscaler — environment variables
#
# Copy this file to .env at repo root and fill in the values for the phase
# you're currently working on. .env is gitignored; .env.example is committed.
#
# Not every variable is needed from day one — see CLAUDE.md "Environment
# variables" for a per-phase guide.

# =============================================================================
# Hugging Face — required from Phase 1 onward
# =============================================================================
# Create a Write-scope token at https://huggingface.co/settings/tokens.
# Used for:
#   - Phase 4a: pushing the captioned (LR, HR) dataset to a private HF Hub
#     dataset repo (bradhinkel/sd-image-upscaler-pairs).
#   - Phase 4c/4d: pulling the dataset on the RunPod pod and pushing the
#     trained LoRA back to public HF Hub model repos.
#   - Pulling base models (SD 1.5, ControlNet Tile, BLIP-large): public, but
#     the token avoids unauthenticated rate limits.
HF_TOKEN=
# Where diffusers caches downloaded weights locally. Default ~/.cache/huggingface
# is fine; only set this if you need a different mount.
# HF_HOME=

# =============================================================================
# RunPod — primary cloud training compute (Phase 4c / 4d)
# =============================================================================
# RunPod RTX 5090 32 GB (Blackwell, sm_120) at ~$0.69/hr is the default for
# both LoRA training runs. Same architecture as the local laptop — the cu128
# torch wheels in pyproject.toml run unchanged on the pod.
#   API key: https://www.runpod.io/console/user/settings  (Personal API Keys)
RUNPOD_API_KEY=

# Spend alert across all cloud GPU work (USD). Set BEFORE any paid run.
CLOUD_SPEND_ALERT=20

# =============================================================================
# Modal — required for Phase 6 (serverless GPU backend for the public demo)
# =============================================================================
# Get these via `modal token new` after creating a Modal account.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# =============================================================================
# Frontend deployment — required for Phase 6 (DO droplet frontend)
# =============================================================================
# A small DO droplet (4 GB, no GPU) hosts the Gradio frontend that proxies
# inference to Modal. DO is still the cleanest choice for a single static
# IP + Let's Encrypt cert.
DO_DROPLET_IP=
DO_SSH_KEY_PATH=~/.ssh/id_ed25519
# Optional: subdomain the deployed app will live under.
DEMO_DOMAIN=

# Frontend runtime mode. "local" during Phase 5 development (pipeline runs
# in-process on your GPU); "modal" once Phase 6 is deployed.
UPSCALER_MODE=local

# Rate-limiter config used by the frontend droplet.
RATE_LIMIT_PER_IP_PER_HOUR=3
DAILY_REQUEST_CAP=200
