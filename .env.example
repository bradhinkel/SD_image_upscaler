# SD_image_upscaler — environment variables
#
# Copy this file to .env at repo root and fill in the values for the phase
# you're currently working on. .env is gitignored; .env.example is committed.
#
# Not every variable is needed from day one — see CLAUDE.md "Environment
# variables" for a per-phase guide.

# =============================================================================
# Hugging Face — required from Phase 1 onward (model weight downloads)
# =============================================================================
# Create a read token at https://huggingface.co/settings/tokens
# A write token is only required in Phase 4c/4d if you push LoRA weights.
HF_TOKEN=
# Where diffusers caches downloaded weights locally. Point at a large-volume
# mount (not your WSL OS disk) because SD + SDXL + ControlNet + VAE is multi-GB.
HF_HOME=/mnt/d/hf_cache

# =============================================================================
# DigitalOcean GPU — primary cloud training compute (Phase 4c / 4d)
# =============================================================================
# The plan uses DO GPU droplets (H100 at $3.39/hr) for LoRA training runs.
# Consolidated with Brad's existing DO account — single invoice, same region
# as the DO Spaces bucket for free intra-region transfer.
# Create at: https://cloud.digitalocean.com/account/api/tokens
DO_API_TOKEN=

# Spend alert for the DO account (USD). Set this BEFORE any paid run.
CLOUD_SPEND_ALERT=40

# Optional fallbacks if DO GPU inventory is unavailable in your region.
# RUNPOD_API_KEY=
# LAMBDA_API_KEY=

# =============================================================================
# DigitalOcean Spaces — object storage for training dataset + checkpoints
# =============================================================================
# Used to mirror the captioned (LR, HR) pair dataset from your local machine
# to the GPU droplet, and to save training checkpoints. Prefer same region
# as the GPU droplet so transfers are free and fast.
DO_SPACES_KEY=
DO_SPACES_SECRET=
DO_SPACES_BUCKET=
DO_SPACES_REGION=nyc3

# Optional AWS S3 fallback (unused by default).
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_S3_BUCKET=
# AWS_S3_REGION=

# =============================================================================
# Modal — required for Phase 6 (serverless GPU backend)
# =============================================================================
# Get these via `modal token new` after creating a Modal account.
MODAL_TOKEN_ID=
MODAL_TOKEN_SECRET=

# =============================================================================
# Frontend deployment — required for Phase 6 (DO droplet frontend)
# =============================================================================
DO_DROPLET_IP=
DO_SSH_KEY_PATH=~/.ssh/id_ed25519
# Optional: subdomain the deployed app will live under (for Let's Encrypt).
DEMO_DOMAIN=

# Frontend runtime mode. Set to "local" during Phase 5 development (pipeline
# runs in-process on your GPU) or "modal" once Phase 6 is deployed (pipeline
# offloaded to Modal).
UPSCALER_MODE=local

# Rate-limiter config used by the frontend droplet.
RATE_LIMIT_PER_IP_PER_HOUR=3
DAILY_REQUEST_CAP=200
